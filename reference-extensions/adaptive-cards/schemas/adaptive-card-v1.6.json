{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adaptivecards.io/schemas/1.6.0/adaptive-card.json",
  "title": "AdaptiveCard v1.6",
  "type": "object",
  "required": ["type", "version"],
  "properties": {
    "type": { "const": "AdaptiveCard" },
    "version": { "type": "string", "pattern": "^1\\.[0-6](\\.\\d+)?$" },
    "$schema": { "type": "string" },
    "body": { "type": "array", "items": { "type": "object" } },
    "actions": { "type": "array", "items": { "type": "object" } },
    "speak": { "type": "string" },
    "lang": { "type": "string" },
    "refresh": { "type": "object" },
    "fallbackText": { "type": "string" },
    "backgroundImage": { "oneOf": [{ "type": "string" }, { "type": "object" }] },
    "minHeight": { "type": "string" },
    "rtl": { "type": "boolean" },
    "verticalContentAlignment": { "enum": ["top", "center", "bottom"] },
    "selectAction": { "type": "object" }
  }
}
